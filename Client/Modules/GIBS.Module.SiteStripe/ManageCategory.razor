@using GIBS.Module.SiteStripe.Services
@using GIBS.Module.SiteStripe.Models

@namespace GIBS.Module.SiteStripe
@inherits ModuleBase
@inject ICategoryService ClientCategoryService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<ManageCategory> Localizer

<form @ref="form" class="@(validated ? "was-validated" : "needs-validation")" novalidate>
    <div class="container">
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="name" HelpText="Enter a category name" ResourceKey="Name">Name: </Label>
            <div class="col-sm-9">
                <input id="name" class="form-control" @bind="@_name" @oninput="OnCategoryNameInput" required />
            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="slug" HelpText="Enter a category slug" ResourceKey="Slug">Slug: </Label>
            <div class="col-sm-9">
                <input id="slug" class="form-control" @bind="@_slug" />
            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="parentid" HelpText="Select parent category" ResourceKey="ParentId">Parent Id: </Label>
            <div class="col-sm-9">
                <select id="parentid" class="form-select" @bind="@_parentid" @bind:after="OnParentChanged">
                    <option value="-1">-- None --</option>
                    @RenderOptions(ParentItems)
                </select>
            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="sortorder" HelpText="Enter sort order" ResourceKey="SortOrder">Sort Order: </Label>
            <div class="col-sm-9">
                <input id="sortorder" type="number" class="form-control" @bind="@_sortorder" />
            </div>
        </div>
        <div class="row mb-1 align-items-center">
            <Label Class="col-sm-3" For="isactive" HelpText="Is this category active" ResourceKey="IsActive">Is Active: </Label>
            <div class="col-sm-9">
                <input id="isactive" type="checkbox" class="form-check-input" @bind="@_isactive" />
            </div>
        </div>
    </div>

    <button type="button" class="btn btn-success" @onclick="Save">@Localizer["Save"]</button>
    <NavLink class="btn btn-secondary" href="@NavigateUrl()">@Localizer["Cancel"]</NavLink>
</form>

@if (_categories != null && _categories.Count > 0)
{
    <hr />
    <h5>Existing Categories</h5>
    <Pager Items="@_categories">
        <Header>
            <th style="width: 1px;">&nbsp;</th>
            <th style="width: 1px;">&nbsp;</th>
            <th>@Localizer["Name"]</th>
            <th>@Localizer["Slug"]</th>
            <th style="width: 1px;">&nbsp;</th>
            <th style="width: 1px;">&nbsp;</th>
            <th>@Localizer["SortOrder"]</th>
            <th>@Localizer["IsActive"]</th>
        </Header>
        <Row>
            <td><ActionLink Action="ManageCategory" IconName="pencil" IconOnly="true" Parameters="@($"id=" + context.CategoryId.ToString())" ResourceKey="Edit" /></td>
            <td><ActionDialog Header="Delete Category" IconName="delete" IconOnly="true" Message="Are You Sure You Wish To Delete This Category?" Action="Delete" Security="SecurityAccessLevel.Edit" Class="btn btn-danger" OnClick="@(async () => await Delete(context))" ResourceKey="Delete" Id="@context.CategoryId.ToString()" /></td>
            <td>@context.Name</td>
            <td>@context.Slug</td>
            <td>
                <button type="button" class="btn btn-outline-primary" title="Move Up" @onclick="@(async () => await MoveUp(context))" disabled="@(context.SortOrder == _categories.Where(c => c.ParentId == context.ParentId).Min(c => c.SortOrder))"><i class="oi oi-arrow-circle-top"></i></button>
            </td>
            <td>
                <button type="button" class="btn btn-outline-primary" title="Move Down" @onclick="@(async () => await MoveDown(context))" disabled="@(context.SortOrder == _categories.Where(c => c.ParentId == context.ParentId).Max(c => c.SortOrder))"><i class="oi oi-arrow-circle-bottom"></i></button>
            </td>
            <td style="width:80px;" class="text-center">@context.SortOrder</td>
            <td style="width:80px;" class="text-center">@context.IsActive</td>
        </Row>
    </Pager>
}

@code {
    public override SecurityAccessLevel SecurityAccessLevel => SecurityAccessLevel.Edit;

    public override string Actions => "ManageCategory";

    public override string Title => "Manage Categories";

    public override List<Resource> Resources => new List<Resource>()
    {
        new Stylesheet("_content/GIBS.Module.SiteStripe/Module.css")
    };

    private ElementReference form;
    private bool validated = false;

    private int _id;
    private int _siteId;
    private string _name;
    private string _slug;
    private int _parentid;
    private int _sortorder;
    private bool _isactive = true;
    private List<Category> _categories = new();
    private List<Category> ParentItems = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadCategories();
            _siteId = ModuleState.SiteId;

            if (PageState.QueryString.ContainsKey("id") && int.TryParse(PageState.QueryString["id"], out _id))
            {
                var category = await ClientCategoryService.GetCategoryAsync(_id, ModuleState.ModuleId);
                if (category != null)
                {
                    _name = category.Name;
                    _slug = category.Slug;
                    _parentid = category.ParentId;
                    _sortorder = category.SortOrder;
                    _isactive = category.IsActive;
                    _siteId = category.SiteId;
                    ParentItems = BuildTree(_categories.Where(c => c.CategoryId != _id).ToList());
                }
            }
            else
            {
                _sortorder = GetNextSortOrder(_parentid);
                _siteId = ModuleState.SiteId;
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Loading Categories {Error}", ex.Message);
            AddModuleMessage(Localizer["Message.LoadError"], MessageType.Error);
        }
    }

    private async Task LoadCategories()
    {
        _categories = (await ClientCategoryService.GetCategoriesAsync(ModuleState.ModuleId))
            .OrderBy(c => c.ParentId)
            .ThenBy(c => c.SortOrder)
            .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
        ParentItems = BuildTree(_categories);
    }

    private Task OnParentChanged()
    {
        if (_id == 0)
        {
            _sortorder = GetNextSortOrder(_parentid);
        }

        return Task.CompletedTask;
    }

    private int GetNextSortOrder(int parentId)
    {
        var maxSortOrder = _categories
            .Where(c => c.ParentId == parentId)
            .Select(c => (int?)c.SortOrder)
            .Max() ?? 0;

        return maxSortOrder + 1;
    }

    private void OnCategoryNameInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        _name = value;
        _slug = GenerateSlug(value);
    }

    private string GenerateSlug(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return "";
        var slug = new string(input.ToLower().Select(c =>
            (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') ? c :
            (c == ' ' ? '-' : '\0')).Where(c => c != '\0').ToArray());
        slug = System.Text.RegularExpressions.Regex.Replace(slug, "-+", "-");
        slug = slug.Trim('-');
        return slug;
    }

    private async Task Save()
    {
        try
        {
            validated = true;
            var interop = new Oqtane.UI.Interop(JSRuntime);
            if (await interop.FormValid(form))
            {
                if (_id == 0)
                {
                    var category = new Category
                    {
                        ModuleId = ModuleState.ModuleId,
                        Name = _name,
                        Slug = string.IsNullOrWhiteSpace(_slug) ? (_name ?? string.Empty).Trim().ToLowerInvariant().Replace(" ", "-") : _slug,
                        ParentId = _parentid,
                        SortOrder = _sortorder,
                        IsActive = _isactive,
                        SiteId = ModuleState.SiteId
                    };

                    await ClientCategoryService.AddCategoryAsync(category);
                    await logger.LogInformation("Category Added {Category}", category);
                }
                else
                {
                    var category = await ClientCategoryService.GetCategoryAsync(_id, ModuleState.ModuleId);
                    if (category != null)
                    {
                        category.Name = _name;
                        category.Slug = string.IsNullOrWhiteSpace(_slug) ? (_name ?? string.Empty).Trim().ToLowerInvariant().Replace(" ", "-") : _slug;
                        category.ParentId = _parentid;
                        category.SortOrder = _sortorder;
                        category.IsActive = _isactive;
                        category.SiteId = _siteId;
                        await ClientCategoryService.UpdateCategoryAsync(category);
                        await logger.LogInformation("Category Updated {Category}", category);
                    }
                }

                await LoadCategories();
                ResetForm();
                StateHasChanged();
            }
            else
            {
                AddModuleMessage(Localizer["Message.SaveValidation"], MessageType.Warning);
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Saving Category {Error}", ex.Message);
            AddModuleMessage(Localizer["Message.SaveError"], MessageType.Error);
        }
    }

    private void ResetForm()
    {
        _id = 0;
        _name = string.Empty;
        _slug = string.Empty;
        _parentid = 0;
        _sortorder = GetNextSortOrder(_parentid);
        _isactive = true;
        _siteId = ModuleState.SiteId;
        validated = false;
    }

    private async Task Delete(Category category)
    {
        try
        {
            await ClientCategoryService.DeleteCategoryAsync(category.CategoryId, ModuleState.ModuleId);
            await logger.LogInformation("Category Deleted {Category}", category);
            await LoadCategories();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Deleting Category {Category} {Error}", category, ex.Message);
            AddModuleMessage(Localizer["Message.DeleteError"], MessageType.Error);
        }
    }

    private List<Category> BuildTree(List<Category> flatList)
    {
        var lookup = flatList.ToDictionary(x => x.CategoryId);
        var rootItems = new List<Category>();

        foreach (var item in flatList)
        {
            if (item.ParentId == 0 || !lookup.ContainsKey(item.ParentId))
            {
                rootItems.Add(item);
            }
            else
            {
                lookup[item.ParentId].Children.Add(item);
            }
        }

        return rootItems;
    }

    private RenderFragment RenderOptions(IEnumerable<Category> items, int level = 0) => builder =>
    {
        int seq = 0;
        foreach (var item in items)
        {
            builder.OpenElement(seq++, "option");
            builder.AddAttribute(seq++, "value", item.CategoryId);
            builder.AddContent(seq++, new string('\u00A0', level * 4) + item.Name);
            builder.CloseElement();

            if (item.Children != null && item.Children.Count > 0)
            {
                builder.AddContent(seq++, RenderOptions(item.Children, level + 1));
            }
        }
    };

    private async Task MoveUp(Category category)
    {
        try
        {
            var previousItem = _categories
                .Where(c => c.ParentId == category.ParentId && c.SortOrder < category.SortOrder)
                .OrderByDescending(c => c.SortOrder)
                .FirstOrDefault();

            if (previousItem != null)
            {
                var current = await ClientCategoryService.GetCategoryAsync(category.CategoryId, ModuleState.ModuleId);
                var previous = await ClientCategoryService.GetCategoryAsync(previousItem.CategoryId, ModuleState.ModuleId);

                if (current != null && previous != null)
                {
                    int tempOrder = current.SortOrder;
                    current.SortOrder = previous.SortOrder;
                    previous.SortOrder = tempOrder;

                    await ClientCategoryService.UpdateCategoryAsync(current);
                    await ClientCategoryService.UpdateCategoryAsync(previous);

                    await LoadCategories();

                    if (_id == current.CategoryId)
                    {
                        _sortorder = current.SortOrder;
                    }
                    else if (_id == previous.CategoryId)
                    {
                        _sortorder = previous.SortOrder;
                    }

                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Moving Category Up {Error}", ex.Message);
            AddModuleMessage(Localizer["Message.SaveError"], MessageType.Error);
        }
    }

    private async Task MoveDown(Category category)
    {
        try
        {
            var nextItem = _categories
                .Where(c => c.ParentId == category.ParentId && c.SortOrder > category.SortOrder)
                .OrderBy(c => c.SortOrder)
                .FirstOrDefault();

            if (nextItem != null)
            {
                var current = await ClientCategoryService.GetCategoryAsync(category.CategoryId, ModuleState.ModuleId);
                var next = await ClientCategoryService.GetCategoryAsync(nextItem.CategoryId, ModuleState.ModuleId);

                if (current != null && next != null)
                {
                    int tempOrder = current.SortOrder;
                    current.SortOrder = next.SortOrder;
                    next.SortOrder = tempOrder;

                    await ClientCategoryService.UpdateCategoryAsync(current);
                    await ClientCategoryService.UpdateCategoryAsync(next);

                    await LoadCategories();

                    if (_id == current.CategoryId)
                    {
                        _sortorder = current.SortOrder;
                    }
                    else if (_id == next.CategoryId)
                    {
                        _sortorder = next.SortOrder;
                    }

                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            await logger.LogError(ex, "Error Moving Category Down {Error}", ex.Message);
            AddModuleMessage(Localizer["Message.SaveError"], MessageType.Error);
        }
    }
}
