@using GIBS.Module.SiteStripe.Services
@using GIBS.Module.SiteStripe.Models

@namespace GIBS.Module.SiteStripe.List
@inherits ModuleBase
@inject ISiteStripeService ClientSiteStripeService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<Index> Localizer
@inject ISettingService SettingService

@if (_SiteStripes == null)
{
    <p><em>Loading...</em></p>
}
else
{
    var displayTemplate = _displayTemplate?.Trim() ?? string.Empty;

    @if (FilteredSiteStripes.Count != 0)
    {
        if (string.Equals(displayTemplate, "TextOnly", StringComparison.OrdinalIgnoreCase))
        {
            <div class="list-group">
                @foreach (var siteStripe in PagedSiteStripes)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center gap-3">
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@siteStripe.Name</div>
                            <div class="text-muted small">@(string.IsNullOrWhiteSpace(siteStripe.CategoryName) ? siteStripe.ProductCategory : siteStripe.CategoryName)</div>
                        </div>
                        <a href="@siteStripe.AffiliateURL"
                           target="@(siteStripe.OpenInNewTab ? "_blank" : "_self")"
                           rel="@siteStripe.RelAttribute" title="@siteStripe.Name"
                           class="btn btn-outline-primary btn-sm text-nowrap">@((MarkupString)_defaultButtonText)</a>
                    </div>
                }
            </div>
        }
        else if (string.Equals(displayTemplate, "SmallCard", StringComparison.OrdinalIgnoreCase))
        {
            <div class="row g-3">
                @foreach (var siteStripe in PagedSiteStripes)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 site-stripe-small-card">
                            @if (!string.IsNullOrWhiteSpace(siteStripe.ImageURL))
                            {
                                <img src="@siteStripe.ImageURL" alt="@siteStripe.Name" class="card-img-top img-fluid" />
                            }
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title mb-1">@siteStripe.Name</h6>
                                <p class="card-text text-muted small mb-3">@(string.IsNullOrWhiteSpace(siteStripe.CategoryName) ? siteStripe.ProductCategory : siteStripe.CategoryName)</p>
                                <a href="@siteStripe.AffiliateURL"
                                target="@(siteStripe.OpenInNewTab ? "_blank" : "_self")"
                                rel="@siteStripe.RelAttribute" 
                                   class="btn btn-outline-primary btn-lg mt-auto">@((MarkupString)_defaultButtonText)</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (string.Equals(displayTemplate, "Showcase", StringComparison.OrdinalIgnoreCase))
        {
            <div class="row g-3">
                @foreach (var siteStripe in PagedSiteStripes)
                {
                    <div class="col-12">
                        <div class="card h-100 site-stripe-showcase-card">
                            <div class="row g-0">
                                @if (!string.IsNullOrWhiteSpace(siteStripe.ImageURL))
                                {
                                    <div class="col-md-4">
                                        <img src="@siteStripe.ImageURL" alt="@siteStripe.Name" class="img-fluid rounded-start site-stripe-showcase-image" />
                                    </div>
                                }
                                <div class="col-md-8">
                                    <div class="card-body d-flex flex-column h-100">
                                        <h5 class="card-title mb-1">@siteStripe.Name</h5>
                                        <p class="card-text text-muted small mb-3">@(string.IsNullOrWhiteSpace(siteStripe.CategoryName) ? siteStripe.ProductCategory : siteStripe.CategoryName)</p>
                                        <div  class="mb-3">@((MarkupString)siteStripe.RawHTMLEmbed)</div>
                                        <a href="@siteStripe.AffiliateURL"
                                           target="@(siteStripe.OpenInNewTab ? "_blank" : "_self")"
                                           rel="@siteStripe.RelAttribute"
                                           class="btn btn-outline-primary btn-lg mt-auto">@((MarkupString)_defaultButtonText)</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (string.Equals(displayTemplate, "Carousel", StringComparison.OrdinalIgnoreCase))
        {
            <div id="gibsSSCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
                <div class="carousel-inner" role="listbox">
                    @for (var slideIndex = 0; slideIndex < CarouselSlides.Count; slideIndex++)
                    {
                        var slideItems = CarouselSlides[slideIndex];
                        <div class="carousel-item @(slideIndex == 0 ? "active" : "")">

                            @* FIX 1: Removed 'col-12 col-md-6' from the child and instead
                       used row-cols utilities here.
                       - 'row-cols-1': 1 card on mobile
                       - 'row-cols-md-2': 2 cards on tablet
                       - 'row-cols-lg-@CarouselItemsPerSlide': Dynamically outputs 1, 2, 4, or 6 on desktop!  
                    *@
                          
                            <div class="carousel-slide-content row row-cols-1 row-cols-md-2 row-cols-lg-@CarouselItemsPerSlide g-3 justify-content-centerw-100 mx-0">
                                @for (var itemIndex = 0; itemIndex < slideItems.Length; itemIndex++)
                                {
                                    var siteStripe = slideItems[itemIndex];
                                    var loadingMode = slideIndex == 0 && itemIndex < CarouselItemsPerSlide ? "eager" : "lazy";

                                    <div class="col d-flex">
                                        @* 'd-flex' ensures the card stretches to the row height *@
                                        <div class="card h-100 w-100 site-stripe-carousel-card">
                                            @if (!string.IsNullOrWhiteSpace(siteStripe.ImageURL))
                                            {
                                                <a href="@siteStripe.AffiliateURL"
                                                   target="@(siteStripe.OpenInNewTab ? "_blank" : "_self")"
                                                   rel="@siteStripe.RelAttribute"
                                                   class="carousel-card-image-link"
                                                   title="@siteStripe.Name">
                                                    <img src="@siteStripe.ImageURL"
                                                         class="carousel-card-image"
                                                         alt="@siteStripe.Name"
                                                         style="max-height:@(_imageHeight);"
                                                         loading="@loadingMode"
                                                         decoding="async" />
                                                </a>
                                            }
                                            @* FIX 2: Added 'h-100' here so mt-auto pushes the button down properly *@
                                            <div class="card-body d-flex flex-column h-100">
                                                <h6 class="card-title mb-1">@siteStripe.SmallName</h6>
                                                <p class="card-text text-muted small mb-3">@(string.IsNullOrWhiteSpace(siteStripe.CategoryName) ? siteStripe.ProductCategory : siteStripe.CategoryName)</p>
                                                <a href="@siteStripe.AffiliateURL"
                                                   target="@(siteStripe.OpenInNewTab ? "_blank" : "_self")"
                                                   rel="@siteStripe.RelAttribute"
                                                   class="btn btn-outline-primary btn-sm mt-auto">@((MarkupString)_defaultButtonText)</a>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <a class="carousel-control-prev carousel-control-btn" data-bs-target="#gibsSSCarousel" role="button" data-bs-slide="prev" aria-label="Previous slide">
                    <i class="bi bi-chevron-left fs-6"></i>
                </a>
                <a class="carousel-control-next carousel-control-btn" data-bs-target="#gibsSSCarousel" role="button" data-bs-slide="next" aria-label="Next slide">
                    <i class="bi bi-chevron-right fs-6"></i>
                </a>
            </div>
        }

        @if (TotalPages > 1 && !string.Equals(displayTemplate, "Carousel", StringComparison.OrdinalIgnoreCase))
        {
            <nav class="mt-3" aria-label="SiteStripe pagination">
                <ul class="pagination pagination-sm justify-content-center">
                    <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                        @if (_currentPage > 1)
                        {
                            <a href="@GetPageUrl(_currentPage - 1)" class="page-link">Previous</a>
                        }
                        else
                        {
                            <span class="page-link">Previous</span>
                        }
                    </li>
                    @for (var pageNumber = 1; pageNumber <= TotalPages; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == _currentPage ? "active" : "")" aria-current="@(pageNumber == _currentPage ? "page" : null)">
                            @if (pageNumber == _currentPage)
                            {
                                <span class="page-link">@pageNumber</span>
                            }
                            else
                            {
                                <a href="@GetPageUrl(pageNumber)" class="page-link">@pageNumber</a>
                            }
                        </li>
                    }
                    <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                        @if (_currentPage < TotalPages)
                        {
                            <a href="@GetPageUrl(_currentPage + 1)" class="page-link">Next</a>
                        }
                        else
                        {
                            <span class="page-link">Next</span>
                        }
                    </li>
                </ul>
            </nav>
        }

        <div class="row mt-4 mb-2">
            <div class="col-12 col-md-6 offset-md-3">
                <p class="text-muted text-center mb-0" style="font-size: 12px;">@_defaultDisclosureStatement</p>
            </div>
        </div>

    }
    else
    {
        <p>@Localizer["Message.DisplayNone"]</p>
    }
}

@code {
    public override string RenderMode => RenderModes.Static;

    public override List<Resource> Resources => new List<Resource>()
    {
        new Stylesheet("_content/GIBS.Module.SiteStripe/Module.css?v=13"),
        new Script("_content/GIBS.Module.SiteStripe/Module.js?v=7")
    };

    private int _pageSize = 10;

    List<SiteStripe> _SiteStripes;
    private int _currentPage = 1;
    private string _displayTemplate;
    private string _imageHeight;
    private int _numberVisible = 5;
    private string _defaultDisclosureStatement;
    private string _defaultButtonText = "Check Price on Amazon";

    private List<SiteStripe> FilteredSiteStripes => _SiteStripes?
        .Where(item => item.IsActive)
        .ToList() ?? new List<SiteStripe>();

    private IEnumerable<SiteStripe> PagedSiteStripes => FilteredSiteStripes
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize);

    private int CarouselItemsPerSlide => Math.Max(1, _numberVisible);

    private List<SiteStripe[]> CarouselSlides => FilteredSiteStripes
        .Chunk(CarouselItemsPerSlide)
        .ToList();

    private int TotalPages => (int)Math.Ceiling((double)FilteredSiteStripes.Count / _pageSize);

    protected override async Task OnInitializedAsync()
       {
           try
           {
               string pageSizeStr = SettingService.GetSetting(ModuleState.Settings, "PageSize", "8");
               if (int.TryParse(pageSizeStr, out int pageSize))
               {
                   _pageSize = pageSize;
               }
               _displayTemplate = SettingService.GetSetting(ModuleState.Settings, "DisplayTemplate", "SmallCard");
               _imageHeight = SettingService.GetSetting(ModuleState.Settings, "ImageHeight", "300px");
            _numberVisible = int.TryParse(SettingService.GetSetting(ModuleState.Settings, "NumberVisible", "5"), out int numberVisible) ? numberVisible : 5;
            _defaultDisclosureStatement = SettingService.GetSetting(ModuleState.Settings, "DefaultDisclosureStatement", "As an Amazon Associate, I earn from qualifying purchases");
            _defaultButtonText = SettingService.GetSetting(ModuleState.Settings, "DefaultButtonText", "Check Price on Amazon");

            var siteStripes = await ClientSiteStripeService.GetSiteStripesBySiteIdAsync(ModuleState.SiteId);
            _SiteStripes = siteStripes.OrderByDescending(s => s.ModifiedOn).ToList();
             //  _SiteStripes = await ClientSiteStripeService.GetSiteStripesBySiteIdAsync(ModuleState.SiteId);

               // Get page number from query parameters
               var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
               _currentPage = 1;

               if (!string.IsNullOrWhiteSpace(uri.Query))
               {
                   var queryParams = uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);
                   foreach (var queryParam in queryParams)
                   {
                       var keyValue = queryParam.Split('=', 2);
                       if (keyValue.Length == 2
                           && string.Equals(keyValue[0], "page", StringComparison.OrdinalIgnoreCase)
                           && int.TryParse(Uri.UnescapeDataString(keyValue[1]), out var parsedPage)
                           && parsedPage > 0)
                       {
                           _currentPage = parsedPage;
                           break;
                       }
                   }
               }
           }
           catch (Exception ex)
           {
               await logger.LogError(ex, "Error Loading SiteStripe {Error}", ex.Message);
               AddModuleMessage(Localizer["Message.LoadError"], MessageType.Error);
           }
       }

    private string GetPageUrl(int page)
    {
        return NavigationManager.GetUriWithQueryParameter("page", page);
    }
}
